# ── Copy this to .env and fill in your values ──

SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
SITE_NAME=EventBook
FRONTEND_URL=http://localhost:8000
TIME_ZONE=Africa/Lagos

# Database (leave blank to use SQLite locally)
# On Render this is set automatically
DATABASE_URL=

# Email (leave as console for local dev — emails print to terminal)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=EventBook <noreply@eventbook.ng>

# Paystack (get from dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PLATFORM_FEE_PERCENT=5
